#!/usr/bin/env bash
# topdf is a wrapper for a standard Pandoc configuration for rendering a
# simple Markdown file as a PDF. Requires pandoc, xelatex.
#
# Usage:
#   pandoc <filename.md>
#   # You can pass additional pandoc arguments.
#   pandoc <filename.md> --toc

# ARG WRANGLING
if [[ $# -eq 0 ]] ; then
    blog error "No input file specified.";
    bashdoc "$BASH_SOURCE";
    exit 1;
fi
INFILE=$1
NAME=${1%.md}
PDFNAME=${NAME}.pdf

# Check for --tufte flag
TUFTE_ARGS=()
PASSTHROUGH_ARGS=()
for arg in "${@:2}"; do
    if [[ "$arg" == "--tufte" ]]; then
        TUFTE_ARGS=(
            --variable documentclass=tufte-handout
            --variable classoption=notoc
            # macOS system Palatino has no GSUB table, so \textsc{} silently
            # renders as regular text. TeX Gyre Pagella is a Palatino clone with
            # real OpenType smallcaps (smcp). Requires the tex-gyre TeX Live
            # package AND the .otf files copied to ~/Library/Fonts/ so fontconfig
            # (and thus XeTeX) can find them by name.
            -V mainfont="TeX Gyre Pagella"
            # Workaround for tufte-latex + soul + LaTeX3 incompatibility: the
            # running headers pass \plaintitle through \smallcaps, which nests
            # \MakeTextLowercase inside soul's \sodef spacing. The LaTeX3 kernel
            # (TeX Live 2025+) changed \MakeTextLowercase's expansion in a way
            # soul can't handle, crashing with "extra }". See tufte-fixes.tex.
            -H "$(dirname "$BASH_SOURCE")/tufte-fixes.tex"
        )
    else
        PASSTHROUGH_ARGS+=("$arg")
    fi
done

# PROCESSING
sed -e 's/––/---/g' ${INFILE} | # Better em-dashes
sed -e 's/<br>/\\\newline /g' | # Support <br> for line breaks. Add any other operations after this...
pandoc --from=markdown --pdf-engine=xelatex --request-header "User-Agent:pandoc" -o ${PDFNAME} --variable urlcolor=NavyBlue "${TUFTE_ARGS[@]}" "${PASSTHROUGH_ARGS[@]}"

# Exit code from the last command.
pandoc_status="$?"
case $pandoc_status in
  0)
    blog info "Created $PDFNAME."
    ;;
  *)
    blog error "Failed to generate PDF. See above for details."
    exit $pandoc_status
    ;;
esac
